{% extends 'layouts/base.twig' %}

{% block content %}
<section class="home-hero">
    <div class="hero-slider" data-hero-slider>
        <div class="hero-slider__track" data-hero-track>
            {% for slide in slides %}
                <a class="hero-slide {{ loop.first ? 'is-active' : '' }}" href="{{ slide.resolved_link_url }}" data-hero-slide aria-label="{{ slide.title }}">
                    <img src="{{ slide.image_url }}" alt="{{ slide.title }}">
                    <div class="hero-slide__overlay"></div>
                    <div class="hero-slide__content">
                        <span class="hero-slide__eyebrow">JH collection</span>
                        <h2>{{ slide.title }}</h2>
                        {% if slide.subtitle %}
                            <p>{{ slide.subtitle }}</p>
                        {% endif %}
                        <span class="hero-slide__cta">{{ slide.button_label }}</span>
                    </div>
                </a>
            {% else %}
                <div class="hero-slide is-active">
                    <div class="hero-slide__content">
                        <h2>Slide non disponibili</h2>
                    </div>
                </div>
            {% endfor %}
        </div>
        {% if slides|length > 1 %}
            <div class="hero-slider__dots" data-hero-dots>
                {% for slide in slides %}
                    <button class="hero-slider__dot {{ loop.first ? 'is-active' : '' }}" type="button" data-hero-dot aria-label="Vai alla slide {{ loop.index }}"></button>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

<section class="category-strip">
    <div class="section-heading">
        <h2>Acquista per linea</h2>
    </div>
    <div class="grid grid--3">
        {% for category in categories %}
            {% include 'components/category-card.twig' with { category: category } %}
        {% else %}
            <p>Nessuna categoria disponibile al momento.</p>
        {% endfor %}
    </div>
</section>

<section class="featured-strip">
    <div class="section-heading">
        <h2>Prodotti in evidenza</h2>
    </div>
    <div class="grid grid--3">
        {% for product in featuredProducts %}
            {% include 'components/product-card.twig' with { product: product } %}
        {% else %}
            <p>Non ci sono ancora prodotti pubblicati.</p>
        {% endfor %}
    </div>
</section>
{% endblock %}
