{% extends 'layouts/base.twig' %}

{% block content %}
<section class="hero hero--compact">
    <span class="eyebrow">Catalogo</span>
    <h1>Catalogo</h1>
    <p>Esplora le linee gia pubblicate del laboratorio: gioielli, resina, stampa 3D e prodotti pensati per essere richiesti anche in versione personalizzata.</p>
    <div class="hero__actions">
        <a class="button" href="{{ app.url }}/contatti">Richiedi un prodotto</a>
        <a class="button button--ghost" href="{{ app.url }}/laboratorio">Approfondisci il laboratorio</a>
    </div>
</section>

<section>
    <div class="section-heading">
        <h2>Naviga per categoria</h2>
    </div>
    <div class="grid grid--3">
        {% for category in categories %}
            {% include 'components/category-card.twig' with { category: category } %}
        {% else %}
            <p>Nessuna categoria disponibile.</p>
        {% endfor %}
    </div>
</section>

<section>
    <div class="section-heading">
        <h2>Prodotti pubblicati</h2>
        <p>Ogni scheda prodotto puo diventare il punto di partenza per una richiesta diretta o per una personalizzazione.</p>
    </div>
    <div class="grid grid--3">
        {% for product in products %}
            {% include 'components/product-card.twig' with { product: product } %}
        {% else %}
            <p>Non ci sono ancora prodotti pubblicati in questa fase.</p>
        {% endfor %}
    </div>
</section>
{% endblock %}
