{% extends 'layouts/base.twig' %}

{% block content %}
<section>
    <h1>Catalogo</h1>
    <p>Questa vista legge categorie e prodotti direttamente dal database, con una base pronta per filtri e futura area admin.</p>
</section>

<section>
    <div class="section-heading">
        <h2>Categorie</h2>
    </div>
    <div class="grid grid--3">
        {% for category in categories %}
            {% include 'components/category-card.twig' with { category: category } %}
        {% else %}
            <p>Nessuna categoria disponibile.</p>
        {% endfor %}
    </div>
</section>

<section>
    <div class="section-heading">
        <h2>Prodotti pubblicati</h2>
    </div>
    <div class="grid grid--3">
        {% for product in products %}
            {% include 'components/product-card.twig' with { product: product } %}
        {% else %}
            <p>Non ci sono ancora prodotti pubblicati. Possiamo aggiungere subito i primi record seed.</p>
        {% endfor %}
    </div>
</section>
{% endblock %}
