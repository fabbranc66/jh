{% extends 'layouts/admin.twig' %}

{% block content %}
<section>
    <span class="eyebrow">Navigazione</span>
    <h1>Categorie e sottocategorie menu</h1>
    <p class="section-note">Le categorie sono le voci principali. Le sottocategorie sono le opzioni del mega menu e possono avere immagine propria.</p>
    {% include 'components/flash.twig' %}
</section>

<section class="section-tight">
    <details class="admin-collapsible" {{ old ? 'open' : '' }}>
        <summary>Nuovo elemento menu</summary>
        <form class="admin-form admin-form--compact" method="post" action="{{ app.url }}/admin/menu">
            {% include 'components/csrf.twig' %}
            <div class="compact-grid compact-grid--3">
                <label>
                    <span>Nome</span>
                    <input type="text" name="label" value="{{ old.label|default('') }}" required>
                </label>
                <label>
                    <span>URL</span>
                    <input type="text" name="url" value="{{ old.url|default('') }}" placeholder="/catalogo" required>
                </label>
                <label>
                    <span>Tipo</span>
                    <select name="parent_id">
                        <option value="0">Categoria principale</option>
                        {% for parent in parents %}
                            <option value="{{ parent.id }}" {{ old.parent_id|default('0') == parent.id ? 'selected' : '' }}>Sottocategoria di {{ parent.label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label>
                    <span>Ordine</span>
                    <input type="number" name="sort_order" value="{{ old.sort_order|default('0') }}">
                </label>
                <label class="checkbox">
                    <input type="checkbox" name="is_active" {{ old ? (old.is_active is defined ? 'checked' : '') : 'checked' }}>
                    <span>Elemento attivo</span>
                </label>
            </div>
            <button class="button button--small" type="submit">Crea elemento</button>
        </form>
    </details>
</section>

<section class="section-tight">
    <h2>Struttura attuale</h2>
    <div class="menu-tree">
        {% set currentParentId = null %}
        {% for item in items %}
            {% if item.parent_id is null %}
                {% if currentParentId is not null %}
                    </div>
                </section>
                {% endif %}
                {% set currentParentId = item.id %}
                <section class="menu-group" data-menu-group>
                    <article class="menu-child-card menu-child-card--parent">
                        <div class="menu-child-card__media">
                            {% if item.image_path %}
                                <img class="admin-thumb admin-thumb--list" src="{{ app.url }}/{{ item.image_path }}?v={{ app.asset_version }}" alt="{{ item.label }}">
                            {% else %}
                                <span class="menu-child-card__placeholder">Categoria</span>
                            {% endif %}
                        </div>
                        <div class="menu-child-card__content">
                            <div class="menu-table__title menu-table__title--child">
                                <span class="menu-table__kind">Categoria</span>
                                <button
                                    class="menu-group__name-toggle"
                                    type="button"
                                    data-menu-toggle
                                    aria-expanded="true"
                                    title="Clicca per aprire o chiudere le sottocategorie"
                                    data-help="Clicca per aprire o chiudere le sottocategorie"
                                >
                                    {{ item.label }}
                                </button>
                            </div>
                            <div class="menu-child-card__meta">
                                <span>{{ item.url }}</span>
                                <span>#{{ item.sort_order }}</span>
                                <span>{{ item.is_active ? 'Attiva' : 'Off' }}</span>
                            </div>
                        </div>
                        <div class="admin-row-actions">
                            <a class="pill pill--link menu-table__link--parent" href="{{ app.url }}/admin/menu/{{ item.id }}/modifica">Modifica</a>
                            <form method="post" action="{{ app.url }}/admin/menu/{{ item.id }}/su">
                                {% include 'components/csrf.twig' %}
                                <button class="button button--ghost button--tiny" type="submit">Su</button>
                            </form>
                            <form method="post" action="{{ app.url }}/admin/menu/{{ item.id }}/giu">
                                {% include 'components/csrf.twig' %}
                                <button class="button button--ghost button--tiny" type="submit">Giu</button>
                            </form>
                        </div>
                    </article>
                    <div class="menu-group__body" data-menu-body>
            {% else %}
                        <article class="menu-child-card">
                            <div class="menu-child-card__media">
                                {% if item.image_path %}
                                    <img class="admin-thumb admin-thumb--list" src="{{ app.url }}/{{ item.image_path }}?v={{ app.asset_version }}" alt="{{ item.label }}">
                                {% else %}
                                    <span class="menu-child-card__placeholder">Nessuna immagine</span>
                                {% endif %}
                            </div>
                            <div class="menu-child-card__content">
                                <div class="menu-table__title menu-table__title--child">
                                    <span class="menu-table__kind">Sottocategoria</span>
                                    <a class="pill pill--link menu-table__link--child" href="{{ app.url }}/admin/menu/{{ item.id }}/modifica">
                                        {{ item.label }}
                                    </a>
                                </div>
                                <div class="menu-child-card__meta">
                                    <span>{{ item.url }}</span>
                                    <span>#{{ item.sort_order }}</span>
                                    <span>{{ item.is_active ? 'Attiva' : 'Off' }}</span>
                                </div>
                            </div>
                            <div class="admin-row-actions">
                                <form method="post" action="{{ app.url }}/admin/menu/{{ item.id }}/su">
                                    {% include 'components/csrf.twig' %}
                                    <button class="button button--ghost button--tiny" type="submit">Su</button>
                                </form>
                                <form method="post" action="{{ app.url }}/admin/menu/{{ item.id }}/giu">
                                    {% include 'components/csrf.twig' %}
                                    <button class="button button--ghost button--tiny" type="submit">Giu</button>
                                </form>
                            </div>
                        </article>
            {% endif %}
        {% else %}
            <p>Nessun elemento menu presente.</p>
        {% endfor %}
        {% if currentParentId is not null %}
                    </div>
                </section>
        {% endif %}
    </div>
</section>
{% endblock %}
