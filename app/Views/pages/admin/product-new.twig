{% extends 'layouts/admin.twig' %}

{% block content %}
<section>
    <span class="eyebrow">Admin prodotti</span>
    <h1>Nuovo prodotto</h1>
    <p>Crea un nuovo articolo in una pagina dedicata, senza affollare l'elenco prodotti.</p>
    {% if flash %}
        <div class="flash flash--{{ flash.type }}">{{ flash.message }}</div>
    {% endif %}
</section>

<section>
    <form class="admin-form" method="post" action="{{ app.url }}/admin/prodotti">
        {% include 'components/csrf.twig' %}
        <label>
            <span>Categoria</span>
            <select name="category_id" required>
                <option value="">Seleziona una categoria</option>
                {% for category in categories %}
                    <option value="{{ category.id }}">{{ category.name }}</option>
                {% endfor %}
            </select>
        </label>
        <label>
            <span>Nome prodotto</span>
            <input type="text" name="name" required>
        </label>
        <label>
            <span>SKU</span>
            <input type="text" name="sku">
        </label>
        <label>
            <span>Descrizione breve</span>
            <input type="text" name="short_description">
        </label>
        <label>
            <span>Descrizione completa</span>
            <textarea name="description" rows="5"></textarea>
        </label>
        <label>
            <span>Materiali</span>
            <input type="text" name="materials">
        </label>
        <label>
            <span>Tecnica</span>
            <input type="text" name="technique">
        </label>
        <label>
            <span>Etichetta prezzo</span>
            <input type="text" name="price_label" value="Prezzo su richiesta">
        </label>
        <label>
            <span>Stato</span>
            <select name="status">
                <option value="draft">Bozza</option>
                <option value="published">Pubblicato</option>
            </select>
        </label>
        <div class="checkbox-grid">
            <label class="checkbox"><input type="checkbox" name="is_customizable"><span>Personalizzabile</span></label>
            <label class="checkbox"><input type="checkbox" name="is_featured"><span>In evidenza</span></label>
            <label class="checkbox"><input type="checkbox" name="whatsapp_enabled" checked><span>WhatsApp</span></label>
            <label class="checkbox"><input type="checkbox" name="telegram_enabled" checked><span>Telegram</span></label>
            <label class="checkbox"><input type="checkbox" name="share_enabled" checked><span>Condivisione</span></label>
        </div>
        <div class="hero__actions">
            <button class="button" type="submit">Salva prodotto</button>
            <a class="button button--ghost" href="{{ app.url }}/admin/prodotti">Torna ai prodotti</a>
        </div>
    </form>
</section>
{% endblock %}
