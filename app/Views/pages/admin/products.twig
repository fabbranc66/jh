{% extends 'layouts/admin.twig' %}

{% block content %}
<section>
    <span class="eyebrow">Admin prodotti</span>
    <h1>Prodotti</h1>
    <p>Inserimento rapido del catalogo con status, personalizzazione e visibilita.</p>
    {% if flash %}
        <div class="flash flash--{{ flash.type }}">{{ flash.message }}</div>
    {% endif %}
</section>

<section>
    <h2>Elenco prodotti</h2>
    <div class="hero__actions">
        <a class="button" href="{{ app.url }}/admin/prodotti/nuovo">Nuovo prodotto</a>
    </div>
    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Anteprima</th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>SKU</th>
                    <th>Stato</th>
                </tr>
            </thead>
            <tbody>
                {% for product in products %}
                    <tr>
                        <td>{{ product.id }}</td>
                        <td>
                            {% if product.primary_image_url %}
                                <img class="admin-thumb admin-thumb--list" src="{{ product.primary_image_url }}" alt="{{ product.name }}">
                            {% else %}
                                <span class="pill pill--soft">Nessuna</span>
                            {% endif %}
                        </td>
                        <td>
                            <a class="pill pill--link" href="{{ app.url }}/admin/prodotti/{{ product.id }}/modifica">{{ product.name }}</a>
                        </td>
                        <td>{{ product.category_name }}</td>
                        <td>{{ product.sku ?: 'N/D' }}</td>
                        <td>{{ product.status }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">Nessun prodotto presente.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
