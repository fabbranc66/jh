{% extends 'layouts/admin.twig' %}

{% block content %}
<section>
    <span class="eyebrow">Admin contatti</span>
    <h1>Richieste contatto</h1>
    <p class="section-note">Messaggi inviati dal form pubblico del sito.</p>
    {% include 'components/flash.twig' %}
</section>

<section>
    <form class="admin-form admin-form--compact" method="get" action="{{ app.url }}/admin/contatti">
        <div class="compact-grid compact-grid--2 compact-grid--align-end">
            <label>
                <span>Cerca</span>
                <input type="text" name="q" value="{{ filters.q }}">
            </label>
            <label>
                <span>Stato</span>
                <select name="status">
                    <option value="">Tutti</option>
                    <option value="new" {{ filters.status == 'new' ? 'selected' : '' }}>Nuovo</option>
                    <option value="in_progress" {{ filters.status == 'in_progress' ? 'selected' : '' }}>In lavorazione</option>
                    <option value="done" {{ filters.status == 'done' ? 'selected' : '' }}>Completato</option>
                    <option value="archived" {{ filters.status == 'archived' ? 'selected' : '' }}>Archiviato</option>
                </select>
            </label>
        </div>
        <div class="hero__actions">
            <button class="button button--small" type="submit">Filtra</button>
            <a class="button button--ghost button--small" href="{{ app.url }}/admin/contatti">Reset</a>
        </div>
    </form>
</section>

<section>
    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Telefono</th>
                    <th>IP</th>
                    <th>Messaggio</th>
                    <th>Prodotto</th>
                    <th>Stato</th>
                    <th>Azione</th>
                </tr>
            </thead>
            <tbody>
                {% for request in requests %}
                    <tr>
                        <td>{{ request.id }}</td>
                        <td>{{ request.name }}</td>
                        <td>{{ request.email ?: 'N/D' }}</td>
                        <td>{{ request.phone ?: 'N/D' }}</td>
                        <td><code>{{ request.ip_address ?: 'N/D' }}</code></td>
                        <td>{{ request.message }}</td>
                        <td>{{ request.product_name ?: 'Generico' }}</td>
                        <td>{{ request.status }}</td>
                        <td>
                            <form class="inline-status" method="post" action="{{ app.url }}/admin/contatti/{{ request.id }}/stato">
                                {% include 'components/csrf.twig' %}
                                <select name="status">
                                    <option value="new" {{ request.status == 'new' ? 'selected' : '' }}>Nuovo</option>
                                    <option value="in_progress" {{ request.status == 'in_progress' ? 'selected' : '' }}>In lavorazione</option>
                                    <option value="done" {{ request.status == 'done' ? 'selected' : '' }}>Completato</option>
                                    <option value="archived" {{ request.status == 'archived' ? 'selected' : '' }}>Archiviato</option>
                                </select>
                                <button class="button button--ghost button--tiny" type="submit">Salva</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9">Nessuna richiesta contatto presente.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% include 'components/pagination.twig' with { pagination: pagination } %}
</section>
{% endblock %}
