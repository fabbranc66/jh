{% extends 'layouts/admin.twig' %}

{% block content %}
<section>
    <span class="eyebrow">Contenuti</span>
    <h1>Pagine e sottocategorie</h1>
    <p class="section-note">Ogni pagina del menu puo avere contenuti dedicati e una propria immagine.</p>
    {% include 'components/flash.twig' %}
</section>

<section class="section-tight">
    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Anteprima</th>
                    <th>Pagina</th>
                    <th>Slug</th>
                    <th>Stato</th>
                </tr>
            </thead>
            <tbody>
                {% for page in pages %}
                    <tr>
                        <td>
                            {% if page.image_path %}
                                <img class="admin-thumb admin-thumb--list" src="{{ app.url }}/{{ page.image_path }}?v={{ app.asset_version }}" alt="{{ page.title }}">
                            {% else %}
                                <span class="section-note">N/D</span>
                            {% endif %}
                        </td>
                        <td><a class="pill pill--link" href="{{ app.url }}/admin/pagine/{{ page.id }}/modifica">{{ page.title }}</a></td>
                        <td>{{ page.slug }}</td>
                        <td>{{ page.is_active ? 'Attiva' : 'Off' }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4">Nessuna pagina disponibile.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
