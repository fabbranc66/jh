{% extends 'layouts/admin.twig' %}

{% block content %}
<section>
    <span class="eyebrow">Backoffice</span>
    <h1>Dashboard mini admin</h1>
    <p>Base leggera per gestire il catalogo senza dipendere da CMS o pannelli complessi.</p>
    {% include 'components/flash.twig' %}
</section>

<section>
    <div class="grid grid--2">
        <article class="card">
            <h2>Categorie</h2>
            <p>{{ categories|length }} presenti nel catalogo.</p>
            <a class="button" href="{{ app.url }}/admin/categorie">Gestisci categorie</a>
        </article>
        <article class="card">
            <h2>Prodotti</h2>
            <p>{{ productsCount }} presenti nel catalogo.</p>
            <div class="hero__actions">
                <a class="button" href="{{ app.url }}/admin/prodotti">Gestisci prodotti</a>
                <a class="button button--ghost" href="{{ app.url }}/admin/prodotti/nuovo">Nuovo prodotto</a>
            </div>
        </article>
        <article class="card">
            <h2>Contatti</h2>
            <p>{{ contactsCount }} richieste salvate dal form pubblico.</p>
            <a class="button" href="{{ app.url }}/admin/contatti">Apri richieste</a>
        </article>
    </div>
</section>
{% endblock %}
