{% extends 'layouts/base.twig' %}

{% block content %}
<section class="hero hero--compact">
    <span class="eyebrow">Pagina</span>
    <h1>{{ page.title }}</h1>
    <p>{{ page.meta_description ?: 'Contenuto informativo del progetto.' }}</p>
</section>

<section>
    <div class="rich-text card card--compact">
        <p>{{ page.content }}</p>
    </div>
</section>
{% endblock %}
